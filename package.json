{
  "name": "research-box",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "ResearchBox 定性研究工具箱 - AI 定性研究 PWA 工作台",
  "scripts": {
    "start": "concurrently -k -n ASR,AI,WEB -c teal,yellow,cyan \"npm run asr\" \"npm run ai\" \"npm run dev\"",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "preview": "vite preview",
    "asr": ".\\ai-proxy\\.venv\\Scripts\\python.exe asr-agent/main.py",
    "ai": ".\\ai-proxy\\.venv\\Scripts\\python.exe ai-proxy/main.py",
    "asr:install": ".\\ai-proxy\\.venv\\Scripts\\python.exe -m pip install -r asr-agent/requirements.txt",
    "gen-templates": "npx tsx scripts/generate-native-templates.ts",
    "open": "powershell -ExecutionPolicy Bypass -File scripts/start-researchbox.ps1",
    "deploy": "npm run build && cd worker && npx wrangler deploy",
    "deploy:build": "npm run build",
    "deploy:worker": "cd worker && npx wrangler deploy",
    "deploy:dev": "cd worker && npx wrangler dev"
  },
  "dependencies": {
    "dexie": "^4.0.10",
    "dexie-react-hooks": "^1.1.7",
    "docx": "^8.5.0",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "mammoth": "^1.12.0",
    "pptx-automizer": "^0.8.2",
    "pptxgenjs": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "wavesurfer.js": "^7.8.6",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "postcss": "^8.4.49",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^7.3.6",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
