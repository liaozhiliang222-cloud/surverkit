# ============================================================
# ResearchBox .gitignore
# 策略：只推送云端部署相关代码（前端 + Cloudflare Worker）
# 本地专用服务（ASR、Python 代理）保留在本地但不入库
# ============================================================

# ====== 依赖与构建产物 ======
node_modules/
dist/
worker/dist/
tsconfig.tsbuildinfo
*.tsbuildinfo

# ====== 本地环境变量（含密钥，严禁入库） ======
.env.local
.env.*.local
*.local.json

# ====== ASR Agent（本地专用，不入库） ======
asr-agent/
ASR_AGENT_SETUP.md

# ====== Python AI 代理（已被 Cloudflare Worker 替代，本地保留） ======
ai-proxy/
ai-proxy/.venv/
ai-proxy/__pycache__/
ai-proxy/**/__pycache__/
ai-proxy/*.log
ai-proxy/*.sqlite3
AI_PROXY_SETUP.md

# ====== 通用 Python 缓存 ======
.venv/
__pycache__/
**/__pycache__/
*.pyc

# ====== Cloudflare 本地状态 ======
.wrangler/

# ====== 临时与调试文件 ======
tmp-*
.tmp-qual-excel/
.artifact-inspect/
*.log

# ====== 操作系统与编辑器 ======
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
